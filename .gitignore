# --- Build output ---
dist/
# the binary, wherever it lands (repo root, or server/ from `go build ./...`)
proxyctl
*.tmp

# --- Local dev scratch (scripts/localstart.sh + scripts/localdev.sh) ---
.localdata/

# --- UI build artefacts ---
# kubeUI/ is the React source; the bundle is regenerated by `npm run build`
# (driven from build.sh / Dockerfile) and never committed.
kubeUI/node_modules/
kubeUI/dist/
# Ignore Vite output but keep the dir + a .gitkeep placeholder so //go:embed
# has something to embed on a fresh clone before the first `npm run build`.
# The `!server/web/dist/` un-ignores the directory itself — without it the
# broad `dist/` rule above excludes the whole dir, so `git add -A` (incl.
# sync-public's public snapshot) drops the .gitkeep and CI's bare `go build`
# fails with "pattern all:web/dist: no matching files found".
!server/web/dist/
server/web/dist/*
!server/web/dist/.gitkeep

# --- Runtime data + state (created when the binary runs; per-instance,
#     never belongs in git) ---
entries.json
domains.json
droplet.json
applied.hash
applied.snapshot.json
apply-state.json
known_hosts

# --- Credentials (NEVER commit — per-instance secrets) ---
.cf-token
cf.token
droplet.key
.runtime-token
*.key

# --- Logs / process cruft ---
*.log
out.log
pid

# --- Internal / private (not part of the public project) ---
*NOTES.md
CLAUDE.md
.claude/
scripts/sync-public.sh
scripts/localstart.sh
scripts/localdev.sh
scripts/clusterdeploy.sh
